{
  "manifest_version": 3,
  "name": "Nika_Keeper",
  "description": "Ника блокирует все сайты после N минут в браузере и устраивает вам перерыв.",
  "version": "1.0.0",

  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],

  "options_page": "options.html",

  "action": {
    "default_title": "Nika Keeper"
  }
}